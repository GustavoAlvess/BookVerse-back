generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// Obras, livros
model Livro {
    id           Int    @id @default(autoincrement())
    titulo       String
    autor        String
    genero_pt    String
    genero_en    String
    ano          Int
    movimento_pt String
    movimento_en String

    // Descrições e Textos (Conteúdo Multilíngue)
    descricao_pt String
    descricao_en String

    enredo_pt String?
    enredo_en String?

    contexto_historico_pt String?
    contexto_historico_en String?

    detalhes_autor_pt String?
    detalhes_autor_en String?

    estilo_escrita_pt String?
    estilo_escrita_en String?

    verossimilhanca_pt String?
    verossimilhanca_en String?

    caracteristicas_literarias_pt String?
    caracteristicas_literarias_en String?

    conclusao_pt String?
    conclusao_en String?

    video_url String?
    capa_url  String?

    // RELACIONAMENTOS
    personagens  Personagem[]
    simulados    Simulado[]
    curiosidades Curiosidade[]

    criado_em DateTime @default(now()) @map("created_at")

    @@map("livros")
}

// Personagens
model Personagem {
    id           Int     @id @default(autoincrement())
    livro_id     Int
    nome         String
    descricao_pt String
    descricao_en String
    papel        String? // Ex: Protagonista, Antagonista
    imagem_url   String?

    // RELACIONAMENTOS
    livro Livro @relation(fields: [livro_id], references: [id], onDelete: Cascade)

    @@map("personagens")
}

// Simulados (Quizzes)
model Simulado {
    id          Int    @id @default(autoincrement())
    livro_id    Int
    pergunta_pt String
    pergunta_en String

    // Opções em português
    opcao_a String
    opcao_b String
    opcao_c String
    opcao_d String

    // Opções em inglês
    opcao_a_en String
    opcao_b_en String
    opcao_c_en String
    opcao_d_en String

    resposta_correta String

    // Feedback pedagógico
    explicacao_pt String?
    explicacao_en String?

    // RELACIONAMENTOS
    livro Livro @relation(fields: [livro_id], references: [id], onDelete: Cascade)

    @@map("simulados")
}

// Dicas, Redação e Curiosidades

enum Categoria {
    Dicas
    Redacao
    Curiosidades
}
enum Categoria_en {
    Tips
    Writing
    Curiosities
}

model Curiosidade {
    id           Int    @id @default(autoincrement())
    livro_id     Int
    categoria_pt Categoria
    categoria_en Categoria_en
    titulo_pt    String
    titulo_en    String
    conteudo_pt  String
    conteudo_en  String

    // RELACIONAMENTOS
    livro Livro @relation(fields: [livro_id], references: [id], onDelete: Cascade)

    @@map("curiosidades")
}

// Usuários
model Usuario {
    id         Int    @id @default(autoincrement())
    nome       String
    email      String @unique
    senha_hash String

    @@map("usuarios")
}

// Equipe
model Equipe {
    id       Int    @id @default(autoincrement())
    nome     String
    objetivo String
    curso    String
    fotoURL  String

    @@map("equipes")
}
